{
  "manifest_version": 3,
  "name": "Anki Clipper",
  "version": "1.2",
  "description": "Создавай карточки Anki из буфера обмена через AI",
  "permissions": ["storage", "clipboardRead", "notifications", "alarms", "contextMenus"],
  "host_permissions": [
    "http://localhost/*",
    "https://api.groq.com/*",
    "<all_urls>"
  ],
  "icons": {
    "16":  "icons/icon16.png",
    "48":  "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16":  "icons/icon16.png",
      "48":  "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "options_page": "options/options.html",
  "background": {
    "service_worker": "background/service-worker.js"
  }
}
